GENGSCOPE_API_PORT=8010
GENGSCOPE_POSTGRES_PORT=54329

# Optional API protection for /api/*.
# Existing unscoped keys default to admin.
GENGSCOPE_API_KEYS=read-key,reviewer-key,admin-key
GENGSCOPE_API_KEY_ROLES=read-key:read,reviewer-key:reviewer,admin-key:admin

# Optional upstream identity/rate-limit friendliness.
OPENALEX_EMAIL=
HTTP_TIMEOUT_SECONDS=20

# Default: 50 MiB.
ARTIFACT_FETCH_MAX_BYTES=52428800

# Keep disabled for deployment unless you explicitly need to fetch from a trusted private mirror.
ARTIFACT_FETCH_ALLOW_PRIVATE_NETWORKS=0

# Optional politeness delay per hostname for remote artifact downloads.
ARTIFACT_FETCH_MIN_INTERVAL_SECONDS=0
