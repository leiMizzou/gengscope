{
  "version": 1,
  "notes": [
    "These deterministic fixtures are regression baselines for analyzer outputs.",
    "Expected signals are review-priority signals only and must not be interpreted as misconduct conclusions."
  ],
  "cases": [
    {
      "id": "numeric_duplicate_and_last_digit",
      "analyzer": "numeric",
      "entity": {
        "entity_type": "author",
        "query": "Alice Zhang",
        "limit": 10
      },
      "artifact": {
        "doi": "10.1234/example.paper",
        "artifact_type": "source_data",
        "filename": "golden-source-data.csv",
        "content_type": "text/csv",
        "csv_lines": [
          "replicate,tumor_a,tumor_b,tumor_copy,last_digit",
          "r1,1.10,4.11,1.10,10",
          "r2,2.20,5.12,2.20,20",
          "r3,3.30,6.13,3.30,30",
          "r4,4.40,7.14,4.40,40",
          "r5,5.50,8.15,5.50,50",
          "r6,6.60,9.16,6.60,60",
          "r7,7.70,10.17,7.70,70",
          "r8,8.80,11.18,8.80,80",
          "r9,9.90,12.19,9.90,90",
          "r10,10.00,13.10,10.00,100"
        ]
      },
      "request": {
        "min_duplicate_length": 3,
        "min_last_digit_sample": 10,
        "priority": 8
      },
      "expected": {
        "min_signal_count": 2,
        "signal_types": ["numeric_duplicate_sequence", "numeric_last_digit_anomaly"],
        "human_review_label": "review_required",
        "expected_review_decision": "needs_more_evidence",
        "misconduct_conclusion": false
      }
    },
    {
